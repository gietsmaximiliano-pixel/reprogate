{
  "name": "@reprogate/spec",
  "version": "0.1.0",
  "description": "ReproGate Evidence Manifest types, schema, normalization, hashing, and scoring.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema.json": "./dist/schema.json"
  },
  "files": [
    "dist",
    "examples",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/clean-dist.mjs dist && tsc -p tsconfig.build.json && node scripts/write-schema.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}
